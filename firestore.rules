rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check if user has isAdmin flag in their profile
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // --- User Profile ---
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Campaigns (Public) ---
    match /campaigns_public/{campaignId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // --- Posts (Approved) ---
    match /posts_approved/{postId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    // --- Gallery ---
    match /gallery/{imageId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    // --- Ideas ---
    match /ideas/{ideaId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    // --- Chatrooms ---
    match /chatrooms/{chatroomId} {
      allow get, list: if true;
      allow write: if isSignedIn();
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Inventory (Packages & Addons) ---
    match /packages/{packageId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    match /addons/{addonId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // --- Bookings & Custom Requests ---
    match /custom_bookings/{bookingId} {
      allow create: if true; // Allow guests to request custom safaris
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- Videos ---
    match /videos/{videoId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // --- Admin Roles (Legacy support) ---
    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
