
{
  "entities": {
    "Package": {
      "title": "Package",
      "type": "object",
      "description": "Base foundation for the custom safari builder.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "basePrice": { "type": "number" },
        "durationDays": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" }
      }
    },
    "Addon": {
      "title": "Addon",
      "type": "object",
      "description": "Optional activities or upgrades for safaris.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["activity", "luxury", "extension"] },
        "subCategory": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Campaign": {
      "title": "Campaign",
      "type": "object",
      "description": "A specific tour or expedition listing.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "shortDescription": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "region": { "type": "string", "enum": ["Western", "Eastern", "Northern", "Central", "Other"] },
        "currentAmount": { "type": "number", "description": "Used as traveller rating percentage" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "BlogPost": {
      "title": "BlogPost",
      "type": "object",
      "description": "Community or admin journal entries.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Published", "Hidden", "Reported"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Announcement": {
      "title": "Announcement",
      "type": "object",
      "description": "Admin-posted broadcasts for all travelers.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserDocument": {
      "title": "UserDocument",
      "type": "object",
      "description": "Confidential files assigned to specific users.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "fileUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["Certificate", "Itinerary", "Invoice", "Other"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Idea": {
      "title": "Idea",
      "type": "object",
      "description": "Community suggestions for new dream trips.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "votes": { "type": "number" },
        "voters": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["New", "Under Review", "Approved", "Implemented"] }
      }
    }
  },
  "firestore": {
    "/packages": { "schema": "Package", "description": "Base safari starting points." },
    "/addons": { "schema": "Addon", "description": "Individual activities and upgrades." },
    "/campaigns": { "schema": "Campaign", "description": "Public tour itineraries." },
    "/posts": { "schema": "BlogPost", "description": "Journal entries and travel stories." },
    "/announcements": { "schema": "Announcement", "description": "Site-wide updates." },
    "/user_documents": { "schema": "UserDocument", "description": "Private traveller files." },
    "/ideas": { "schema": "Idea", "description": "Community wishlist and voting." }
  }
}
