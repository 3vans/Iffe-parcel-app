
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a registered traveler or admin.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "isCreator": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "points": { "type": "number" },
        "level": { "type": "string" },
        "followedUserIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "username", "isAdmin", "createdAt"]
    },
    "Campaign": {
      "title": "Campaign",
      "type": "object",
      "description": "A tour expedition itinerary.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "shortDescription": { "type": "string" },
        "region": { "type": "string", "enum": ["Western", "Eastern", "Northern", "Central", "Other"] },
        "goal": { "type": "number" },
        "currentAmount": { "type": "number" },
        "status": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "status"]
    },
    "Departure": {
      "title": "Departure",
      "type": "object",
      "description": "A scheduled group tour departure or event.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["Online", "Offline", "Hybrid"] },
        "excerpt": { "type": "string" },
        "fullDescription": { "type": "string" },
        "imageUrl": { "type": "string" },
        "rsvpLink": { "type": "string" },
        "calendarLink": { "type": "string" }
      },
      "required": ["id", "title", "date", "type"]
    },
    "Package": {
      "title": "Package",
      "type": "object",
      "description": "A base safari foundation package.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "priceDescription": { "type": "string" },
        "durationDays": { "type": "number" },
        "durationText": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "whatsIncluded": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "isPopular": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "includedTours": { "type": "array", "items": { "type": "string" } },
        "itineraryTitle": { "type": "string" },
        "sampleItinerary": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "day": { "type": "number" },
              "activity": { "type": "string" },
              "sections": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "type": { "type": "string", "enum": ["text", "image"] },
                    "content": { "type": "string" },
                    "imageLayout": { "type": "string", "enum": ["small", "full"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "Addon": {
      "title": "Addon",
      "type": "object",
      "description": "An optional activity or upgrade for the safari builder.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["activity", "luxury", "extension"] },
        "subCategory": { "type": "string", "enum": ["Wildlife", "Adventure", "Culture", "Nature & Scenic"] },
        "region": { "type": "string", "enum": ["Central", "Western", "Eastern", "Northern"] },
        "isActive": { "type": "boolean" }
      }
    },
    "CustomBooking": {
      "title": "CustomBooking",
      "type": "object",
      "description": "A booking request generated by the custom builder.",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "basePackage": { "type": "string" },
        "groupSize": { "type": "number" },
        "selectedAddons": { "type": "array", "items": { "type": "string" } },
        "pricing": { "type": "object" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "GalleryImage": {
      "title": "GalleryImage",
      "type": "object",
      "description": "Metadata for photos stored in Supabase.",
      "properties": {
        "id": { "type": "string" },
        "src": { "type": "string" },
        "alt": { "type": "string" },
        "caption": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "storagePath": { "type": "string" }
      }
    },
    "Idea": {
      "title": "Idea",
      "type": "object",
      "description": "A community-suggested destination or trip idea.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "submittedBy": { "type": "string" },
        "votes": { "type": "number" },
        "voters": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["New", "Under Review", "Approved", "Implemented"] },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profiles." }
      },
      {
        "path": "/campaigns_public/{campaignId}",
        "definition": { "entityName": "Campaign", "schema": { "$ref": "#/backend/entities/Campaign" }, "description": "Public expeditions." }
      },
      {
        "path": "/departures/{departureId}",
        "definition": { "entityName": "Departure", "schema": { "$ref": "#/backend/entities/Departure" }, "description": "Scheduled group tours." }
      },
      {
        "path": "/packages/{packageId}",
        "definition": { "entityName": "Package", "schema": { "$ref": "#/backend/entities/Package" }, "description": "Agency safari foundations." }
      },
      {
        "path": "/addons/{addonId}",
        "definition": { "entityName": "Addon", "schema": { "$ref": "#/backend/entities/Addon" }, "description": "Optional activities." }
      },
      {
        "path": "/custom_bookings/{bookingId}",
        "definition": { "entityName": "CustomBooking", "schema": { "$ref": "#/backend/entities/CustomBooking" }, "description": "Builder configurations." }
      },
      {
        "path": "/gallery/{imageId}",
        "definition": { "entityName": "GalleryImage", "schema": { "$ref": "#/backend/entities/GalleryImage" }, "description": "Visual library metadata." }
      },
      {
        "path": "/posts_approved/{postId}",
        "definition": { "schema": "object", "description": "Moderated blog posts." }
      },
      {
        "path": "/ideas/{ideaId}",
        "definition": { "entityName": "Idea", "schema": { "$ref": "#/backend/entities/Idea" }, "description": "Community suggestions." }
      },
      {
        "path": "/chatrooms/{roomId}/messages/{messageId}",
        "definition": { "schema": "object", "description": "Real-time messages." }
      }
    ]
  }
}
