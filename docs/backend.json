
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a registered traveler or admin.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUrl": { "type": "string", "format": "uri" },
        "isCreator": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "points": { "type": "number" },
        "level": { "type": "string" },
        "followedUserIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "username", "isAdmin", "createdAt"]
    },
    "Campaign": {
      "title": "Campaign",
      "type": "object",
      "description": "A tour expedition itinerary.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "shortDescription": { "type": "string" },
        "region": { "type": "string", "enum": ["Western", "Eastern", "Northern", "Central", "Other"] },
        "goal": { "type": "number" },
        "currentAmount": { "type": "number" },
        "status": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "sections": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "image"] },
              "content": { "type": "string" },
              "imageLayout": { "type": "string", "enum": ["small", "full"] }
            }
          }
        },
        "storyline": { "type": "array", "items": { "type": "string" } },
        "activities": { "type": "array", "items": { "type": "object" } },
        "accommodation": { "type": "array", "items": { "type": "object" } },
        "meals": { "type": "array", "items": { "type": "object" } },
        "bookingTips": { "type": "array", "items": { "type": "string" } },
        "organizer": { "type": "string" },
        "volunteersNeeded": { "type": "number" },
        "volunteersSignedUp": { "type": "number" },
        "endDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "status"]
    },
    "Package": {
      "title": "Package",
      "type": "object",
      "description": "A base safari foundation package.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "priceDescription": { "type": "string" },
        "durationDays": { "type": "number" },
        "durationText": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "whatsIncluded": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "isPopular": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "includedTours": { "type": "array", "items": { "type": "string" } },
        "itineraryTitle": { "type": "string" },
        "sampleItinerary": { 
          "type": "array", 
          "items": { 
            "type": "object"
          }
        }
      }
    },
    "CustomBooking": {
      "title": "CustomBooking",
      "type": "object",
      "description": "A booking request generated by the custom builder.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "basePackage": { "type": "string" },
        "groupSize": { "type": "number" },
        "selectedAddons": { "type": "array", "items": { "type": "string" } },
        "pricing": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "contacted", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profiles." }
      },
      {
        "path": "/custom_bookings/{bookingId}",
        "definition": { "entityName": "CustomBooking", "schema": { "$ref": "#/backend/entities/CustomBooking" }, "description": "Client itineraries and process tracking." }
      },
      {
        "path": "/announcements/{announcementId}",
        "definition": { "schema": "object", "description": "Platform broadcast notices." }
      }
    ]
  }
}
