
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // USERS COLLECTION
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // Admin override
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }

    // BOOKINGS COLLECTION
    match /bookings/{bookingId} {
      allow create: if request.auth != null && request.resource.data.userID == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userID == request.auth.uid;

      // Admin override
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }

    // PAYMENTS COLLECTION
    match /payments/{paymentId} {
      // Only admins and backend functions can write payments
      allow create, update, delete: if request.auth != null && request.auth.token.role == "admin";
      
      // Users can only read their own payment records
      allow read: if request.auth != null && resource.data.userID == request.auth.uid;

      // Admin override
      allow read, write: if request.auth != null && request.auth.token.role == "admin";
    }

    // DESTINATIONS COLLECTION
    match /destinations/{destId} {
      allow read: if true; // Everyone can view destinations
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    // PACKAGES COLLECTION
    match /packages/{packageId} {
      allow read: if true; // Everyone can view packages
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    // EMAIL TEMPLATES COLLECTION
    match /emails/{templateId} {
      allow read: if request.auth != null && request.auth.token.role == "admin";
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }
  }
}